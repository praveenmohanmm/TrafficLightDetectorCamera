<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ── Full-screen camera preview ──────────────────────────────────────── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Bounding-box detection overlay ──────────────────────────────────── -->
    <com.poodlesoft.trafficlightdetector.OverlayView
        android:id="@+id/overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Top HUD bar ──────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/hudBar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@color/colorOverlay"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_traffic_signal"
            android:layout_marginEnd="10dp"
            android:contentDescription="Traffic light" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TRAFFIC LIGHT DETECTOR"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Live speed badge -->
        <TextView
            android:id="@+id/speedBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-- km/h"
            android:textColor="@color/colorPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_speed_badge"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp" />

    </LinearLayout>

    <!-- ── Zoom controls pill (right edge, vertically centred) ─────────────── -->
    <LinearLayout
        android:id="@+id/zoomControls"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_zoom_pill"
        android:layout_marginEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hudBar"
        app:layout_constraintBottom_toTopOf="@id/statusCard">

        <!-- Zoom in (+) -->
        <ImageButton
            android:id="@+id/btnZoomIn"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_zoom_in"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Zoom in"
            android:scaleType="center" />

        <!-- Current zoom level label -->
        <TextView
            android:id="@+id/zoomLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1×"
            android:textColor="#90FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

        <!-- Thin divider -->
        <View
            android:layout_width="28dp"
            android:layout_height="1dp"
            android:layout_gravity="center_horizontal"
            android:background="#33FFFFFF"
            android:layout_marginBottom="2dp" />

        <!-- Zoom out (−) -->
        <ImageButton
            android:id="@+id/btnZoomOut"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_zoom_out"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Zoom out"
            android:scaleType="center" />

    </LinearLayout>

    <!-- ── Bottom status card ───────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/statusCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_status_panel"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Coloured state dot -->
        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/shape_circle"
            android:layout_marginEnd="14dp" />

        <!-- Status message -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/scanning"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
